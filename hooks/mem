#!/usr/bin/env python3
"""mem — structured operations on the markdown memory tiers.

Two things must NOT be left to prose, so this tool owns them:

  Forget gate
    - a mechanical staleness check (refs gone? too old and unreferenced?
      explicitly superseded?), and
    - a hard invariant (the archive is append-only; never edit it).

  Per-session working set
    - each session writes its OWN working-set file so two efforts in one
      checkout cannot silently overwrite each other. The session key comes from
      CLAUDE_CODE_SESSION_ID (the same id the checkpoint hook resolves), so the
      hook and the agent's commands agree on the path with no coordination.

Commands:
  mem ws-path        Print this session's working-set file (creating it from the
                     template if absent). Where you WRITE your Now block.
  mem ws-latest      Print the most-recently-touched working-set file. Where a
                     fresh session READS to resume (may be a prior effort's).
  mem ws-dir         Print the git work tree this session last resolved (the
                     breadcrumb the checkpoint hook follows so its checkpoint
                     lands in the same file as your Now, even when the session
                     launched from a different/non-git dir). Empty if none.
  mem ws-gc          Prune working-set files older than WS_TTL_DAYS (default 14),
                     always keeping the latest and the current session's; also
                     prunes stale session breadcrumbs by the same TTL.
  mem gc-scan        List ledger demote candidates: file Refs gone, OR explicitly
                     superseded, OR stale (no live code anchor, older than
                     LEDGER_STALE_DAYS and unreferenced). Invariants and active
                     open-questions are never nominated. Advisory: you decide.
  mem demote <id>    Move a ledger entry to the archive. Appended VERBATIM;
                     existing archive entries are never touched. Immutability is
                     enforced here, structurally.
  mem ls             List ledger entry ids and their Refs.

Paths resolve under the project root (CHECKPOINT_PROJECT_DIR, else git root,
else cwd). Override with LEDGER_FILE / ARCHIVE_FILE. Session id override:
MEM_SESSION_ID (else CLAUDE_CODE_SESSION_ID). Today override (tests): MEM_NOW.
"""
import datetime
import glob
import hashlib
import os
import re
import subprocess
import sys


def project_root():
    """Resolve the project root and whether it came from an organic git
    resolution (as opposed to an explicit CHECKPOINT_PROJECT_DIR override or a
    non-git cwd fallback). The second value gates the session breadcrumb below:
    only a real, override-free git root is worth recording as "where the agent
    is working", so the hook's own override-driven call can never poison it."""
    r = os.environ.get("CHECKPOINT_PROJECT_DIR")
    if r:
        return r, False
    try:
        out = subprocess.check_output(
            ["git", "rev-parse", "--show-toplevel"], stderr=subprocess.DEVNULL
        )
        return out.decode().strip(), True
    except Exception:
        return os.getcwd(), False


ROOT, ROOT_FROM_GIT = project_root()
LEDGER = os.environ.get("LEDGER_FILE", os.path.join(ROOT, "memory/ledger.md"))
ARCHIVE = os.environ.get("ARCHIVE_FILE", os.path.join(ROOT, "memory/archive.md"))
STALE_DAYS = int(os.environ.get("LEDGER_STALE_DAYS", "30"))

# Seed for a fresh per-session working set. Kept in sync with
# templates/memory/working-set.md; the hook rewrites the auto block in place.
SEED_WS = """# Working Set

<!-- The checkpoint hook owns the auto block below. Do not hand-edit it. -->
<!-- checkpoint (none yet) -->
## Checkpoint (auto)

(The hook writes time, git position, status output, and memory-pressure here.)

<!-- Everything below is yours. Replace it in place each meaningful step. -->
<!-- This tier is volatile and bounded: overwrite, do not append. Whatever is -->
<!-- here is what a crash would preserve, so keep it current. -->

## Now

**Task:**
**Live hypothesis:**
**Next step:**
**Blocked on:**

<!-- When a decision crystallizes or an approach is abandoned, promote it to -->
<!-- memory/ledger.md (input gate). Do not let durable facts live only here. -->
"""


# --- session-scoped working set ----------------------------------------------
def session_key():
    """Short, filename-safe key for this session, or None outside a session
    (install verify, manual runs, tests) — in which case the legacy fixed
    working-set.md name is used, preserving backward-compatible behavior."""
    sid = (os.environ.get("MEM_SESSION_ID") or os.environ.get("CLAUDE_CODE_SESSION_ID") or "").strip()
    if not sid:
        return None
    m = re.match(r"[0-9a-fA-F]{8}", sid)
    return m.group(0) if m else hashlib.sha1(sid.encode()).hexdigest()[:8]


def ws_path():
    key = session_key()
    name = f"working-set.{key}.md" if key else "working-set.md"
    return os.path.join(ROOT, "memory", name)


# --- session->dir breadcrumb -------------------------------------------------
# A Claude Code session is anchored to its LAUNCH directory; the checkpoint hook
# resolves from there. But the agent may `cd` into a sub-repo to do its work, so
# its `mem ws-path` resolves to a DIFFERENT root than the hook. Left alone, the
# session's memory splits: the agent writes its narrative to the sub-repo while
# the hook writes empty auto-checkpoints to the launch dir. The hook cannot see
# the agent's transient Bash cwd, so the agent leaves a breadcrumb (the git root
# it resolved) keyed by session, and the hook follows it (see `ws-dir`). Result:
# both writers land in the same working-set file. Best-effort throughout; a
# missing or unwritable breadcrumb just falls back to the launch-dir behavior.
def breadcrumb_path():
    key = session_key()
    if not key:
        return None
    base = os.environ.get("XDG_CACHE_HOME") or os.path.join(
        os.path.expanduser("~"), ".cache"
    )
    return os.path.join(base, "agent-memory-kit", "sessions", f"{key}.dir")


def record_breadcrumb():
    """Record this session's resolved git root, but only when it WAS an organic
    git resolution. Skipped under a CHECKPOINT_PROJECT_DIR override (the hook's
    own call) and for non-git cwd fallbacks, so the recorded dir always points
    at a real work tree the agent chose."""
    if not ROOT_FROM_GIT:
        return
    p = breadcrumb_path()
    if not p:
        return
    try:
        os.makedirs(os.path.dirname(p), exist_ok=True)
        # Write-then-rename so a hook reading concurrently never sees a
        # half-written (empty) breadcrumb and skip the follow. os.replace is
        # atomic within the dir; the pid suffix avoids two writers sharing tmp.
        tmp = f"{p}.{os.getpid()}.tmp"
        with open(tmp, "w") as f:
            f.write(ROOT + "\n")
        os.replace(tmp, p)
    except Exception:
        pass  # never let a breadcrumb failure break ws-path


def read_breadcrumb():
    p = breadcrumb_path()
    if not p:
        return None
    try:
        with open(p) as f:
            d = f.read().strip()
    except Exception:
        return None
    if not d or not os.path.isdir(d):
        return None
    # Follow only a dir that is STILL a git work tree. The breadcrumb is
    # validated at record time, but a `.git` removed before the hook fires
    # would otherwise steer the checkpoint into a now-non-git directory.
    try:
        subprocess.check_output(
            ["git", "-C", d, "rev-parse", "--show-toplevel"],
            stderr=subprocess.DEVNULL,
        )
    except Exception:
        return None
    return d


def cmd_ws_dir():
    d = read_breadcrumb()
    if d:
        print(d)


def ws_glob():
    return sorted(
        glob.glob(os.path.join(ROOT, "memory", "working-set*.md")),
        key=os.path.getmtime,
        reverse=True,
    )


def cmd_ws_path():
    record_breadcrumb()  # remember where the agent is working, for the hook
    p = ws_path()
    if not os.path.exists(p):
        os.makedirs(os.path.dirname(p), exist_ok=True)
        with open(p, "w") as f:
            f.write(SEED_WS)
    print(p)


def cmd_ws_latest():
    record_breadcrumb()  # a resume reads here from the work dir; record it too
    files = ws_glob()
    if files:
        print(files[0])
    else:
        cmd_ws_path()  # none yet: create and print this session's


def cmd_ws_gc():
    ttl_days = float(os.environ.get("WS_TTL_DAYS", "14"))
    files = ws_glob()
    if not files:
        print("no working-set files")
        return
    keep = {os.path.abspath(files[0]), os.path.abspath(ws_path())}
    now = datetime.datetime.now().timestamp()
    removed = []
    for p in files:
        if os.path.abspath(p) in keep:
            continue
        age = (now - os.path.getmtime(p)) / 86400.0
        if age >= ttl_days:
            os.remove(p)
            removed.append((os.path.basename(p), round(age, 1)))
    # Prune stale session breadcrumbs by the same TTL (they live outside the
    # project, so they are not covered by the working-set sweep above).
    bc = breadcrumb_path()
    bc_dir = os.path.dirname(bc) if bc else None
    if bc_dir and os.path.isdir(bc_dir):
        for name in os.listdir(bc_dir):
            fp = os.path.join(bc_dir, name)
            try:
                if os.path.abspath(fp) == os.path.abspath(bc):
                    continue  # keep this session's own breadcrumb
                age = (now - os.path.getmtime(fp)) / 86400.0
                if age >= ttl_days:
                    os.remove(fp)
                    removed.append((name, round(age, 1)))
            except Exception:
                pass
    if removed:
        for name, age in removed:
            print(f"removed {name} ({age}d old)")
    else:
        print(f"nothing to prune (kept latest + current; none older than {ttl_days:g}d)")


# --- ledger parsing ----------------------------------------------------------
def parse_entries(path):
    """Return (entries, lines). An entry is a '### ' block up to the next
    '### ' / '## ' boundary, ignoring lines inside HTML comments. Each entry
    captures id, kind, date, status (from the '### id · kind · date · status'
    header) and Refs."""
    if not os.path.exists(path):
        return [], []
    lines = open(path).read().split("\n")
    n = len(lines)

    starts = []
    in_comment = False
    for idx, line in enumerate(lines):
        was_comment = in_comment
        if "<!--" in line:
            in_comment = True
            was_comment = True
        if "-->" in line:
            in_comment = False
        if not was_comment and line.startswith("### "):
            starts.append(idx)

    entries = []
    for s in starts:
        end = n
        in_c = False
        for j in range(s + 1, n):
            line = lines[j]
            wc = in_c
            if "<!--" in line:
                in_c = True
                wc = True
            if "-->" in line:
                in_c = False
            if wc:
                continue
            if line.startswith("### ") or line.startswith("## "):
                end = j
                break

        header = lines[s][4:]
        parts = [p.strip() for p in header.split("·")]
        m = re.match(r"### (\S+)", lines[s])
        eid = m.group(1) if m else (parts[0].split()[0] if parts and parts[0] else None)
        kind = parts[1].lower() if len(parts) > 1 else ""
        date = parts[2] if len(parts) > 2 else ""
        status = parts[3].lower() if len(parts) > 3 else ""

        refs = []
        for line in lines[s:end]:
            rm = re.match(r"\*\*Refs:\*\*\s*(.*)", line)
            if rm:
                for tok in re.split(r"[,\s]+", rm.group(1)):
                    tok = tok.strip().strip("`").rstrip(".")
                    if tok:
                        refs.append(tok)
        entries.append(
            {"id": eid, "start": s, "end": end, "refs": refs,
             "kind": kind, "date": date, "status": status}
        )
    return entries, lines


def is_filelike(ref):
    if ref.startswith("#") or ref.startswith("[[") or "://" in ref:
        return False
    path = ref.split(":")[0]
    return ("/" in path) or bool(re.search(r"\.\w+$", path))


def ref_exists(ref):
    path = ref.split(":")[0]
    return os.path.exists(os.path.join(ROOT, path))


def today():
    override = os.environ.get("MEM_NOW", "").strip()
    if override:
        try:
            return datetime.date.fromisoformat(override)
        except ValueError:
            pass  # malformed override degrades to the real date, never crashes
    return datetime.date.today()


def age_days(date_str):
    try:
        return (today() - datetime.date.fromisoformat(date_str.strip())).days
    except Exception:
        return None


def cmd_gc_scan():
    entries, lines = parse_entries(LEDGER)
    # Map each [[target]] to the entries that cross-link it, scoped to each
    # entry's own block. An entry is "still load-bearing" only if some OTHER
    # entry links it; a self-link must not immunize an entry from the stale rule.
    # Note: only *file* refs count as a live anchor (see the `not live` check);
    # a bare [[id]] or URL ref is not an anchor, just a cross-link.
    mentions = {}
    for e in entries:
        block = "\n".join(lines[e["start"]:e["end"]])
        for tgt in re.findall(r"\[\[([^\]]+)\]\]", block):
            mentions.setdefault(tgt.strip(), set()).add(e["id"])

    def referenced_by_other(eid):
        return any(src != eid for src in mentions.get(eid, ()))

    candidates = []
    for e in entries:
        kind, status = e["kind"], e["status"]
        # Protect the load-bearing kinds outright.
        if kind == "invariant":
            continue
        if kind == "open-question" and status in ("", "active"):
            continue

        reasons = []
        if status.startswith("superseded"):
            reasons.append("superseded")

        filerefs = [r for r in e["refs"] if is_filelike(r)]
        live = [r for r in filerefs if ref_exists(r)]
        if filerefs and not live:
            reasons.append("all file Refs missing")

        # Ref-less / no-live-anchor garbage: old and cross-linked by no other entry.
        if not live:
            a = age_days(e["date"])
            if a is not None and a >= STALE_DAYS and not referenced_by_other(e["id"]):
                reasons.append(f"stale: no live anchor, {a}d old, unreferenced")

        if reasons:
            candidates.append((e["id"], reasons))

    if not candidates:
        print("no demote candidates: ledger entries are anchored, fresh, or load-bearing")
        return
    print("demote candidates:")
    for eid, reasons in candidates:
        print(f"  {eid}: {'; '.join(reasons)}")
    print("\nReview each (judgment stays yours), then: mem demote <id>")


def cmd_demote(eid):
    entries, lines = parse_entries(LEDGER)
    match = [e for e in entries if e["id"] == eid]
    if not match:
        print(f"error: no ledger entry with id {eid}", file=sys.stderr)
        sys.exit(1)
    e = match[0]
    block = "\n".join(lines[e["start"]:e["end"]]).rstrip()

    new_ledger = "\n".join(lines[: e["start"]] + lines[e["end"]:])
    new_ledger = re.sub(r"\n{3,}", "\n\n", new_ledger).rstrip() + "\n"
    open(LEDGER, "w").write(new_ledger)

    # Append verbatim. This is the ONLY write path to the archive, and it never
    # reads-then-rewrites existing content, so prior entries cannot be altered.
    with open(ARCHIVE, "a") as f:
        f.write("\n" + block + "\n")
    print(f"demoted {eid}: appended to {ARCHIVE} unchanged, removed from {LEDGER}")


def cmd_ls():
    entries, _ = parse_entries(LEDGER)
    for e in entries:
        print(f"{e['id']}\t{' '.join(e['refs'])}")


def main():
    cmd = sys.argv[1] if len(sys.argv) > 1 else ""
    if cmd == "ws-path":
        cmd_ws_path()
    elif cmd == "ws-latest":
        cmd_ws_latest()
    elif cmd == "ws-dir":
        cmd_ws_dir()
    elif cmd == "ws-gc":
        cmd_ws_gc()
    elif cmd == "gc-scan":
        cmd_gc_scan()
    elif cmd == "demote":
        if len(sys.argv) < 3:
            print("usage: mem demote <id>", file=sys.stderr)
            sys.exit(1)
        cmd_demote(sys.argv[2])
    elif cmd == "ls":
        cmd_ls()
    else:
        print("usage: mem {ws-path | ws-latest | ws-dir | ws-gc | gc-scan | demote <id> | ls}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
